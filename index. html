            </div>
          </motion.div>

          <motion.div
            initial={{ opacity: 0, x: 50 }}
            whileInView={{ opacity: 1, x: 0 }}
            viewport={{ once: true }}
            className="space-y-8"
          >
            <div>
              <h3 className="uppercase text-orange-500 text-sm tracking-widest mb-2">Our Mission</h3>
              <p className="text-lg">To build a transparent, prosperous, and equitable India where every voice is heard and every citizen thrives.</p>
            </div>
            <div>
              <h3 className="uppercase text-orange-500 text-sm tracking-widest mb-2">Our Vision</h3>
              <p className="text-lg">A developed India by 2047 where development reaches the last mile and innovation drives national progress.</p>
            </div>
          </motion.div>
        </div>
      </section>

      {/* Leadership Section - Card grid with glow hover */}
      <section id="leadership" className="py-24 bg-gray-100 dark:bg-zinc-950">
        <div className="max-w-6xl mx-auto px-6">
          <motion.h2
            initial={{ opacity: 0 }}
            whileInView={{ opacity: 1 }}
            className="text-5xl font-bold text-center text-orange-600 mb-16"
          >
            Our Leadership
          </motion.h2>

          <div className="grid md:grid-cols-4 gap-8">
            {[
              { name: "Shri Rajesh Kumar", role: "National President", img: "https://picsum.photos/id/64/400/400", desc: "Visionary leader with 25+ years in public service." },
              { name: "Smt. Priya Sharma", role: "National Vice President", img: "https://picsum.photos/id/65/400/400", desc: "Champion of women empowerment and education." },
              { name: "Shri Amit Patel", role: "General Secretary", img: "https://picsum.photos/id/66/400/400", desc: "Youth icon driving digital and economic reforms." },
              { name: "Dr. Anjali Verma", role: "Treasurer", img: "https://picsum.photos/id/67/400/400", desc: "Expert in grassroots development and finance." },
            ].map((leader, i) => (
              <motion.div
                key={i}
                whileHover={{ scale: 1.05, boxShadow: "0 0 30px rgba(249, 115, 22, 0.4)" }}
                initial={{ opacity: 0, y: 40 }}
                whileInView={{ opacity: 1, y: 0 }}
                transition={{ delay: i * 0.1 }}
                className="bg-white dark:bg-zinc-900 rounded-3xl overflow-hidden shadow-xl"
              >
                <img src={leader.img} alt={leader.name} className="w-full h-80 object-cover" />
                <div className="p-8">
                  <h3 className="text-2xl font-semibold">{leader.name}</h3>
                  <p className="text-orange-600 font-medium mt-1">{leader.role}</p>
                  <p className="mt-4 text-sm leading-relaxed text-gray-600 dark:text-gray-400">{leader.desc}</p>
                </div>
              </motion.div>
            ))}
          </div>
        </div>
      </section>

      {/* Initiatives / Campaigns */}
      <section id="initiatives" className="py-24 px-6 max-w-6xl mx-auto">
        <motion.h2
          initial={{ opacity: 0 }}
          whileInView={{ opacity: 1 }}
          className="text-5xl font-bold text-center text-orange-600 mb-16"
        >
          Our Initiatives
        </motion.h2>

        <div className="grid md:grid-cols-3 gap-8">
          {[
            { title: "Development for All", icon: "🏗️", desc: "Infrastructure & rural upliftment across India." },
            { title: "Women Empowerment", icon: "👩‍🦯", desc: "Skill development and safety programs." },
            { title: "Youth Innovation", icon: "🚀", desc: "Startup ecosystem and digital literacy." },
            { title: "Farmer First", icon: "🌾", desc: "Modern agriculture and fair pricing." },
            { title: "Education Reform", icon: "📚", desc: "Quality education for every child." },
            { title: "Green India", icon: "🌍", desc: "Sustainable environment initiatives." },
          ].map((item, i) => (
            <motion.div
              key={i}
              whileHover={{ y: -10 }}
              className="group bg-white dark:bg-zinc-900 p-10 rounded-3xl shadow-xl hover:shadow-2xl transition-all border border-transparent hover:border-orange-200"
            >
              <div className="text-6xl mb-6 group-hover:scale-110 transition-transform">{item.icon}</div>
              <h3 className="text-2xl font-semibold mb-3">{item.title}</h3>
              <p className="text-gray-600 dark:text-gray-400">{item.desc}</p>
            </motion.div>
          ))}
        </div>
      </section>{/* News & Updates */}
      <section id="news" className="py-24 bg-orange-50 dark:bg-zinc-950">
        <div className="max-w-6xl mx-auto px-6">
          <motion.h2
            initial={{ opacity: 0 }}
            whileInView={{ opacity: 1 }}
            className="text-5xl font-bold text-center text-orange-600 mb-16"
          >
            Latest Updates
          </motion.h2>

          <div className="grid md:grid-cols-3 gap-8">
            {[
              { date: "15 Mar 2026", title: "SJP Launches Mega Health Campaign in Bihar", excerpt: "Free medical camps and awareness drives reach 50,000 citizens." },
              { date: "10 Mar 2026", title: "National Youth Summit: Empowering Tomorrow", excerpt: "Over 10,000 young leaders join hands for innovation." },
              { date: "05 Mar 2026", title: "Women Safety Bill Passed in Assembly", excerpt: "Historic legislation introduced by SJP representatives." },
            ].map((news, i) => (
              <motion.div
                key={i}
                whileHover={{ scale: 1.03 }}
                initial={{ opacity: 0 }}
                whileInView={{ opacity: 1 }}
                className="bg-white dark:bg-zinc-900 p-8 rounded-3xl shadow-xl"
              >
                <p className="text-orange-500 text-sm font-medium">{news.date}</p>
                <h3 className="text-2xl font-bold mt-4 mb-3">{news.title}</h3>
                <p className="text-gray-600 dark:text-gray-400 line-clamp-3">{news.excerpt}</p>
                <button className="mt-6 text-orange-600 font-medium hover:underline">Read Full Story →</button>
              </motion.div>
            ))}
          </div>
        </div>
      </section>

      {/* Gallery with Lightbox */}
      <section id="gallery" className="py-24 px-6 max-w-6xl mx-auto">
        <motion.h2
          initial={{ opacity: 0 }}
          whileInView={{ opacity: 1 }}
          className="text-5xl font-bold text-center text-orange-600 mb-16"
        >
          Moments of Change
        </motion.h2>

        <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
          {galleryImages.map((src, i) => (
            <motion.div
              key={i}
              whileHover={{ scale: 1.03 }}
              onClick={() => setSelectedImage(src)}
              className="aspect-video overflow-hidden rounded-3xl cursor-pointer shadow-xl"
            >
              <img src={src} alt={`Gallery ${i}`} className="w-full h-full object-cover hover:scale-110 transition-transform duration-500" />
            </motion.div>
          ))}
        </div>
      </section>

      {/* Lightbox Modal */}
      {selectedImage && (
        <div
          className="fixed inset-0 bg-black/90 z-[200] flex items-center justify-center p-6"
          onClick={() => setSelectedImage(null)}
        >
          <motion.div
            initial={{ scale: 0.8, opacity: 0 }}
            animate={{ scale: 1, opacity: 1 }}
            className="relative max-w-5xl w-full"
            onClick={(e) => e.stopPropagation()}
          >
            <img src={selectedImage} alt="Enlarged" className="rounded-3xl shadow-2xl" />
            <button
              onClick={() => setSelectedImage(null)}
              className="absolute -top-4 -right-4 bg-white text-black w-10 h-10 rounded-full flex items-center justify-center text-2xl shadow-xl"
            >
              ✕
            </button>
          </motion.div>
        </div>
      )}

      {/* Join Party Section - Modern Form */}
      <section id="join" className="py-24 bg-gradient-to-br from-orange-600 to-orange-700 text-white">
        <div className="max-w-2xl mx-auto px-6">
          <div className="text-center mb-12">
            <h2 className="text-5xl font-bold mb-4">Join the Movement</h2>
            <p className="text-xl opacity-90">Become part of India’s fastest growing people’s party</p>
          </div>

          {formSubmitted ? (
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              className="bg-white/10 backdrop-blur-xl p-12 rounded-3xl text-center"
            >
              <div className="text-6xl mb-6">🎉</div>
              <h3 className="text-3xl font-bold">Thank You!</h3>
              <p className="mt-4 text-lg">Your application has been received. Our team will contact you soon.</p>
            </motion.div>
          ) : (
            <form onSubmit={handleFormSubmit} className="space-y-8">
              <div className="grid md:grid-cols-2 gap-6">
                <div>
                  <label className="block text-sm mb-2 font-medium">Full Name *</label>
                  <input
                    type="text"
                    name="name"
                    value={formData.name}
                    onChange={handleInputChange}
                    required
                    className="w-full bg-white/10 border border-white/30 rounded-2xl px-6 py-4 text-lg focus:outline-none focus:border-white placeholder:text-white/60"
                    placeholder="Enter your name"
                  />
                </div>
                <div>
                  <label className="block text-sm mb-2 font-medium">Email *</label>
                  <input
                    type="email"
                    name="email"
                    value={formData.email}
                    onChange={handleInputChange}
                    required
                    className="w-full bg-white/10 border border-white/30 rounded-2xl px-6 py-4 text-lg focus:outline-none focus:border-white placeholder:text-white/60"
