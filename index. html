import React, { useEffect, useState, useRef } from "react";
import { motion, useInView } from "framer-motion";

export default function SJPWebsite() {
  const [darkMode, setDarkMode] = useState(false);
  const [scrollProgress, setScrollProgress] = useState(0);
  const [mobileMenuOpen, setMobileMenuOpen] = useState(false);
  const [selectedImage, setSelectedImage] = useState(null);
  const [formData, setFormData] = useState({
    name: "",
    email: "",
    phone: "",
    state: "Bihar",
    message: "",
  });
  const [formSubmitted, setFormSubmitted] = useState(false);

  // Scroll Progress
  useEffect(() => {
    const handleScroll = () => {
      const totalHeight = document.body.scrollHeight - window.innerHeight;
      const progress = totalHeight > 0 ? (window.scrollY / totalHeight) * 100 : 0;
      setScrollProgress(Math.min(Math.max(progress, 0), 100));
    };
    window.addEventListener("scroll", handleScroll);
    return () => window.removeEventListener("scroll", handleScroll);
  }, []);

  // Smooth scroll helper
  const scrollToSection = (id) => {
    const element = document.getElementById(id);
    if (element) {
      element.scrollIntoView({ behavior: "smooth" });
    }
    setMobileMenuOpen(false);
  };

  // Form handlers
  const handleInputChange = (e) => {
    const { name, value } = e.target;
    setFormData((prev) => ({ ...prev, [name]: value }));
  };

  const handleFormSubmit = (e) => {
    e.preventDefault();
    if (!formData.name || !formData.email || !formData.phone) {
      alert("Please fill in all required fields");
      return;
    }
    // Simulate submission
    setTimeout(() => {
      setFormSubmitted(true);
      setFormData({ name: "", email: "", phone: "", state: "Bihar", message: "" });
      setTimeout(() => setFormSubmitted(false), 3000);
    }, 800);
  };

  // Gallery images (public domain style placeholders)
  const galleryImages = [
    "https://picsum.photos/id/1015/800/600",
    "https://picsum.photos/id/102/800/600",
    "https://picsum.photos/id/1036/800/600",
    "https://picsum.photos/id/1040/800/600",
    "https://picsum.photos/id/106/800/600",
    "https://picsum.photos/id/1074/800/600",
  ];

  // Animated Counter Component
  const AnimatedCounter = ({ end, suffix = "" }) => {
    const ref = useRef(null);
    const isInView = useInView(ref, { once: true, margin: "-100px" });
    const [count, setCount] = useState(0);

    useEffect(() => {
      if (!isInView) return;
      let start = 0;
      const duration = 1800;
      const stepTime = Math.floor(duration / end);
      const timer = setInterval(() => {
        start += Math.ceil(end / 40);
        if (start >= end) {
          setCount(end);
          clearInterval(timer);
        } else {
          setCount(start);
        }
      }, stepTime);
      return () => clearInterval(timer);
    }, [isInView, end]);

    return (
      <span ref={ref} className="text-5xl font-bold text-orange-600 dark:text-orange-400">
        {count.toLocaleString()}{suffix}
      </span>
    );
  };

  return (
    <div className={`${darkMode ? "dark bg-black text-white" : "bg-white text-black"} font-sans`}>
      {/* Scroll Progress Bar */}
      <div
        className="fixed top-0 left-0 h-1 bg-gradient-to-r from-orange-500 to-orange-600 z-[100] transition-all duration-300"
        style={{ width: `${scrollProgress}%` }}
      />

      {/* Navbar - Glassmorphism + Mobile Responsive */}
      <nav className="fixed top-0 w-full backdrop-blur-xl bg-white/90 dark:bg-black/90 border-b border-orange-200 dark:border-orange-900 z-50">
        <div className="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
          {/* Logo */}
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 bg-orange-600 rounded-full flex items-center justify-center text-white font-bold text-2xl shadow-lg">
              S
            </div>
            <h1 className="text-2xl font-bold tracking-tight text-orange-600">SJP</h1>
          </div>
{/* Desktop Menu */}
          <div className="hidden md:flex items-center gap-8 text-sm font-medium">
            <a href="#home" onClick={(e) => { e.preventDefault(); scrollToSection("home"); }} className="hover:text-orange-600 transition-colors">Home</a>
            <a href="#about" onClick={(e) => { e.preventDefault(); scrollToSection("about"); }} className="hover:text-orange-600 transition-colors">About</a>
            <a href="#leadership" onClick={(e) => { e.preventDefault(); scrollToSection("leadership"); }} className="hover:text-orange-600 transition-colors">Leadership</a>
            <a href="#initiatives" onClick={(e) => { e.preventDefault(); scrollToSection("initiatives"); }} className="hover:text-orange-600 transition-colors">Initiatives</a>
            <a href="#news" onClick={(e) => { e.preventDefault(); scrollToSection("news"); }} className="hover:text-orange-600 transition-colors">News</a>
            <a href="#gallery" onClick={(e) => { e.preventDefault(); scrollToSection("gallery"); }} className="hover:text-orange-600 transition-colors">Gallery</a>
            <a href="#join" onClick={(e) => { e.preventDefault(); scrollToSection("join"); }} className="hover:text-orange-600 transition-colors">Join Us</a>
            <button
              onClick={() => setDarkMode(!darkMode)}
              className="text-2xl hover:scale-110 transition-transform"
            >
              {darkMode ? "☀️" : "🌙"}
            </button>
          </div>

          {/* Mobile Menu Button */}
          <button
            onClick={() => setMobileMenuOpen(!mobileMenuOpen)}
            className="md:hidden text-3xl"
          >
            {mobileMenuOpen ? "✕" : "☰"}
          </button>
        </div>

        {/* Mobile Menu */}
        {mobileMenuOpen && (
          <motion.div
            initial={{ opacity: 0, y: -20 }}
            animate={{ opacity: 1, y: 0 }}
            className="md:hidden bg-white dark:bg-black border-t border-orange-200 dark:border-orange-900 px-6 py-6 flex flex-col gap-6 text-lg"
          >
            {["Home", "About", "Leadership", "Initiatives", "News", "Gallery", "Join Us"].map((item, i) => (
              <a
                key={i}
                href={`#${item.toLowerCase().replace(" ", "")}`}
                onClick={(e) => { e.preventDefault(); scrollToSection(item.toLowerCase().replace(" ", "")); }}
                className="hover:text-orange-600"
              >
                {item}
              </a>
            ))}
            <button onClick={() => setDarkMode(!darkMode)} className="text-left text-2xl">
              {darkMode ? "☀️ Light Mode" : "🌙 Dark Mode"}
            </button>
          </motion.div>
        )}
      </nav>

      {/* Hero Section - BJP-inspired grand welcome with animated gradient + subtle wave */}
      <section id="home" className="relative h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-orange-600 via-orange-700 to-orange-800 text-white">
        {/* Animated background layers */}
        <div className="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.15),transparent)] animate-pulse" />
        <div className="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,rgba(255,255,255,0.1),transparent)]" />

        <div className="relative z-10 text-center px-6 max-w-4xl">
          <motion.div
            initial={{ opacity: 0, y: 60 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 1.2, ease: "easeOut" }}
          >
            <div className="inline-flex items-center gap-3 mb-6 bg-white/10 backdrop-blur-md px-6 py-2 rounded-full border border-white/30">
              <span className="text-sm uppercase tracking-[4px]">Sampoorna Janta Party</span>
            </div>

            <h1 className="text-6xl md:text-7xl font-bold leading-none mb-4 tracking-tighter">
              SAMPORNA<br />JANTA PARTY
            </h1>
            <p className="text-2xl md:text-3xl font-light mb-10">Voice of Every Citizen</p>

            <div className="flex flex-col sm:flex-row gap-4 justify-center">
              <motion.button
                whileHover={{ scale: 1.05 }}
                whileTap={{ scale: 0.98 }}
                onClick={() => scrollToSection("join")}
                className="bg-white text-orange-700 hover:bg-orange-100 font-semibold px-10 py-4 rounded-full text-lg shadow-xl transition-all"
              >
                Join Us Now
              </motion.button>
              <motion.button
                whileHover={{ scale: 1.05 }}
                whileTap={{ scale: 0.98 }}
                onClick={() => scrollToSection("join")}
                className="border-2 border-white hover:bg-white/10 font-semibold px-10 py-4 rounded-full text-lg transition-all"
              >
                Donate
              </motion.button>
            </div>
          </motion.div>
        </div>

        {/* Scroll indicator */}
        <motion.div
          initial={{ opacity: 0 }}
          animate={{ opacity: [0.4, 1, 0.4] }}
          transition={{ duration: 2, repeat: Infinity }}
          className="absolute bottom-10 left-1/2 -translate-x-1/2 text-white text-xs tracking-widest flex flex-col items-center"
        >
          SCROLL TO EXPLORE
          <div className="w-px h-12 bg-white/50 mt-3" />
        </motion.div>
      </section>

      {/* About Section */}
      <section id="about" className="py-24 px-6 max-w-6xl mx-auto">
        <div className="grid md:grid-cols-2 gap-16 items-center">
          <motion.div
            initial={{ opacity: 0, x: -50 }}
            whileInView={{ opacity: 1, x: 0 }}
            viewport={{ once: true }}
          >
            <h2 className="text-5xl font-bold text-orange-600 mb-6">About SJP</h2>
            <p className="text-xl leading-relaxed text-gray-700 dark:text-gray-300">
              Sampoorna Janta Party is a people-first political movement dedicated to transparency, inclusive development, and empowering every Indian citizen. Inspired by the spirit of true democracy, we stand for good governance and a brighter future.
            </p>
            <div className="mt-10 grid grid-cols-3 gap-8">
              <div>
                <AnimatedCounter end={500000} />
                <p className="text-sm uppercase tracking-widest mt-2 text-gray-500">Members</p>
              </div>
              <div>
                <AnimatedCounter end={1240} />
                <p className="text-sm uppercase tracking-widest mt-2 text-gray-500">Campaigns</p>
